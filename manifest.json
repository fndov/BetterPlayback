{
  "manifest_version": 3,
  "name": "YouTube Unlimited Playback Rate",
  "version": "1.0.0",
  "description": "Remove the 2x limit from Ctrl+> / Ctrl+< on YouTube.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*", "https://youtu.be/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
